# Copy this to ~/.hermes/.env (read by Hermes gateway) and fill in real values.
# NEVER commit a file with real credentials.

# ── LLM — LiteLLM / OpenAI-compatible ────────────────────────────────────────
OPENAI_API_KEY=                            # LiteLLM key from organizers
OPENAI_BASE_URL=                           # LiteLLM proxy URL from organizers
OPENAI_MODEL=qwen35-35b
HERMES_MODEL=qwen35-35b

# ── Hermes behaviour ─────────────────────────────────────────────────────────
HERMES_YOLO_MODE=1                         # skip approval prompts
TERMINAL_ENV=local

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                        # from @BotFather
TELEGRAM_HOME_CHANNEL=                     # your Telegram user ID (for bot→you messages)
GATEWAY_ALLOW_ALL_USERS=true

# ── Nimble scraper ───────────────────────────────────────────────────────────
NIMBLE_API_KEY=                            # Bearer token (no base64 encoding)
NIMBLE_BASE_URL=                           # Nimble realtime web API endpoint

# ── ClickHouse Cloud ─────────────────────────────────────────────────────────
CLICKHOUSE_HOST=                           # e.g. xyz.us-east-2.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=                           # e.g. nimble_loader
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=pricepilot
CLICKHOUSE_TABLE=price_events
CLICKHOUSE_TRACKED_TABLE=tracked_products

# ── Senso.ai ─────────────────────────────────────────────────────────────────
SENSO_API_KEY=
SENSO_BASE_URL=

# ── Paths (auto-set by setup.sh) ─────────────────────────────────────────────
PRICEPILOT_DIR=                            # absolute path to projects/pricepilot
