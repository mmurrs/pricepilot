# ── LLM — LiteLLM / OpenAI-compatible ─────────────────────────────────────────
OPENAI_API_KEY=                          # LiteLLM API key
OPENAI_BASE_URL=http://localhost:4000    # LiteLLM proxy URL
HERMES_MODEL=openai/claude-sonnet-4-6   # model name as LiteLLM sees it
HERMES_YOLO_MODE=1                       # skip approval prompts during hackathon

# ── Telegram gateway ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                      # from @BotFather
TELEGRAM_ALLOWED_USERS=                  # comma-separated Telegram user IDs (your team)
TELEGRAM_WEBHOOK_URL=                    # public HTTPS URL (use ngrok if local)
TELEGRAM_WEBHOOK_SECRET=pricepilot2026   # any random string

# ── Terminal backend ───────────────────────────────────────────────────────────
TERMINAL_ENV=local                       # use 'daytona' if routing code exec to Daytona
DAYTONA_API_KEY=                         # required if TERMINAL_ENV=daytona

# ── Nimble scraper ─────────────────────────────────────────────────────────────
NIMBLE_API_KEY=
NIMBLE_BASE_URL=https://api.webit.live/api/v1/realtime/web

# ── ClickHouse ─────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=pricepilot

# ── Senso.ai ───────────────────────────────────────────────────────────────────
SENSO_API_KEY=
SENSO_BASE_URL=

# ── PricePilot paths ───────────────────────────────────────────────────────────
PRICEPILOT_DIR=                          # auto-filled by setup.sh
