# =====================================================================
# Connection template for the Nimble → ClickHouse scraping pipeline.
#
# Copy this file to .env.local (gitignored) and fill in the two secret
# values. The non-secret values below are committed on purpose so the
# whole team can clone-and-run without coordinating connection details.
#
# Secrets are NOT in this file. Get them from:
#   - CLICKHOUSE_PASSWORD → 1Password vault "agenticenghack"
#                           (generated by clickhouse-setup.sql STEP 1)
#   - NIMBLE_API_KEY      → Nimble dashboard, copied to the same vault
# =====================================================================

# --- ClickHouse Cloud (non-secret connection info) -------------------
# Hostname from the "Connect" button in the ClickHouse Cloud console.
# Format: <service-id>.<region>.aws.clickhouse.cloud
CLICKHOUSE_HOST=<paste-from-clickhouse-cloud-connect-tab>
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=nimble_loader
CLICKHOUSE_DATABASE=scraping

# --- ClickHouse Cloud (secret) ---------------------------------------
CLICKHOUSE_PASSWORD=

# --- Nimble (secret) -------------------------------------------------
NIMBLE_API_KEY=

# --- Scraper runtime config (non-secret) -----------------------------
# Path on hermes; override locally if you're running the script
# somewhere else for testing.
ASIN_LIST=/opt/nimble-scraper/asins.txt
